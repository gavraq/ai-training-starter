{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/.claude/hooks/LoadMasterPrompt.ts"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write(vault/outputs/**)",
      "Write(*-vault/outputs/**)",
      "Edit(vault/identity/**)",
      "Edit(*-vault/identity/**)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  }
}
