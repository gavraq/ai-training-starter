{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/.claude/hooks/LoadMasterPrompt.ts"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/.claude/hooks/PreCompactFlush.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/.claude/hooks/SessionEndSummary.ts"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write(vault/outputs/**)",
      "Write(*-vault/outputs/**)",
      "Write(vault/daily/**)",
      "Write(*-vault/daily/**)",
      "Edit(vault/identity/**)",
      "Edit(*-vault/identity/**)",
      "Write(vault/identity/MEMORY.md)",
      "Write(*-vault/identity/MEMORY.md)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)"
    ]
  }
}
