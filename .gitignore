# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Environment
.env
.env.local

# Node / Bun
node_modules/
bun.lockb

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local Claude Code state (sessions, logs) and any user-specific
# settings overrides. The shared settings.json IS committed —
# settings.local.json is for personal tweaks that shouldn't leak.
.claude/local/
.claude/sessions/
.claude/settings.local.json

# Personal outputs — keep the .gitkeep but ignore everything else,
# so individual cohort members don't accidentally commit personal digests.
# Patterns cover both `vault/` (default) and `<name>-vault/` (after rename).
vault/outputs/*
!vault/outputs/.gitkeep
*-vault/outputs/*
!*-vault/outputs/.gitkeep

# Personal inputs — same principle. The EXAMPLE is tracked; anything
# else you drop in stays local.
vault/inputs/*
!vault/inputs/EXAMPLE-week.md
*-vault/inputs/*
!*-vault/inputs/EXAMPLE-week.md

# Obsidian workspace metadata — keep your vault config local
.obsidian/workspace*
.obsidian/cache
