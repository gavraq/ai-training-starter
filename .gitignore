# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Environment
.env
.env.local

# Node / Bun
node_modules/
bun.lockb

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local Claude Code state (sessions, logs) and any user-specific
# settings overrides. The shared settings.json IS committed —
# settings.local.json is for personal tweaks that shouldn't leak.
.claude/local/
.claude/sessions/
.claude/settings.local.json

# Personal outputs — keep the .gitkeep but ignore everything else,
# so individual cohort members don't accidentally commit personal digests.
# Patterns cover both `vault/` (default) and `<name>-vault/` (after rename).
vault/outputs/*
!vault/outputs/.gitkeep
*-vault/outputs/*
!*-vault/outputs/.gitkeep

# Personal inputs — same principle. The EXAMPLE is tracked; anything
# else you drop in stays local.
vault/inputs/*
!vault/inputs/EXAMPLE-week.md
*-vault/inputs/*
!*-vault/inputs/EXAMPLE-week.md

# Obsidian — gitignore the entire .obsidian/ folder by default.
# It contains workspace state (panel positions, open files) that changes
# constantly, plus theme/plugin settings that are personal to each machine.
# If you want to share Obsidian config across your own machines later,
# remove this rule and add specific files (e.g. **/.obsidian/community-plugins.json).
# The leading **/ makes the pattern match .obsidian/ anywhere in the tree,
# including inside vault/ or <name>-vault/.
**/.obsidian/
